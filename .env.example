# ForenSight AI — Backend Configuration

# Database
# Uses SQLite locally out-of-the-box. Will auto-create forensight.db
DATABASE_PATH=forensight.db

# Authentication (Firebase)
# For local development without Firebase, set DISABLE_AUTH=true
DISABLE_AUTH=true

# 1. Download your service account key from: 
#    Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# 2. Save it as 'firebase-service-account.json' in this folder and uncomment:
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Docs (Swagger / OpenAPI)
# Set to true for local development, false for production
ENABLE_DOCS=true

# File constraints
MAX_FILE_SIZE_MB=500
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
